# ホワイトリスト方式: デフォルト全無視
*

# 許可するファイル
!.gitignore
!CLAUDE.md
!ARCHITECTURE.md
!plan.md
!pyproject.toml
!uv.lock
!flake.nix
!flake.lock
!.envrc
!config/
!config/**
!src/
!src/**
!strategies/
!strategies/**
!tests/
!tests/**
!scripts/
!scripts/**
!browser_service/
!browser_service/package.json
!browser_service/package-lock.json
!browser_service/server.js
!data/
!data/irbank/
!data/irbank/*/
!data/irbank/**/*.json

# バイナリ・キャッシュは常に除外
__pycache__/
*.pyc
