# ホワイトリスト方式: デフォルト全無視
*

# 許可するファイル
!.gitattributes
!.gitignore
!*.md
!Cargo.lock
!Cargo.toml
!pyproject.toml
!uv.lock
!flake.nix
!flake.lock
!.envrc
!config/
!config/**
!src/
!src/**
src/formula_screening/_core*.so
src/formula_screening/_core*.pyd
!rust/
!rust/src/
!rust/src/**
!strategies/
!strategies/**
!tests/
!tests/**
!scripts/
!scripts/**
!browser_service/
!browser_service/package.json
!browser_service/package-lock.json
!browser_service/server.js
!docs/
!docs/**
!src_ts/
!src_ts/**
!tsconfig.json
!package.json
!package-lock.json
!data/
!data/not_a_proxy.txt
!.claude/hooks/
!.claude/hooks/**
!.claude/settings.local.json

# バイナリ・キャッシュは常に除外
__pycache__/
*.pyc
